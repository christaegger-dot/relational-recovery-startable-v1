# Basis-URL der Produktions-Installation. Wird in folgende Stellen injiziert:
#   - src/data/routeMeta.js (ueber import.meta.env)
#   - index.html (ueber Vite %ENV%-Substitution)
#   - public/robots.txt und public/sitemap.xml (ueber scripts/replace-env.mjs)
#
# Fuer Staging- oder Preview-Deploys diese Variable ueberschreiben.
VITE_BASE_URL=https://eltern-angehoerige-fa.netlify.app
